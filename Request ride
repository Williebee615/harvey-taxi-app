<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Request a Ride</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
    }

    body {
      background: #f5f5f5;
      color: #111;
    }

    .page {
      max-width: 430px;
      margin: 0 auto;
      min-height: 100vh;
      padding: 24px 20px 40px;
      background: #f5f5f5;
    }

    .back {
      display: inline-block;
      margin-bottom: 28px;
      text-decoration: none;
      color: #111;
      font-size: 16px;
      font-weight: 600;
    }

    h1 {
      font-size: 34px;
      font-weight: 800;
      margin-bottom: 12px;
      line-height: 1.1;
    }

    .subtitle {
      font-size: 16px;
      color: #6b7280;
      line-height: 1.5;
      margin-bottom: 34px;
    }

    .label {
      display: block;
      font-size: 15px;
      font-weight: 800;
      margin-bottom: 10px;
      margin-top: 18px;
    }

    .input {
      width: 100%;
      height: 82px;
      border: 2px solid #e5e7eb;
      border-radius: 22px;
      background: #f7f7f7;
      padding: 0 22px;
      font-size: 16px;
      color: #111;
      outline: none;
    }

    .input::placeholder {
      color: #a3a3a3;
      font-weight: 600;
    }

    .input:focus {
      border-color: #111;
      background: #fff;
    }

    .section-title {
      font-size: 30px;
      font-weight: 800;
      margin-top: 34px;
      margin-bottom: 18px;
      line-height: 1.1;
    }

    .ride-option {
      width: 100%;
      border: 2px solid #e5e7eb;
      border-radius: 24px;
      background: #f5f5f5;
      padding: 20px 22px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 18px;
      cursor: pointer;
      transition: 0.15s ease;
    }

    .ride-option.active {
      border-color: #111;
      box-shadow: inset 0 0 0 1px #111;
      background: #fafafa;
    }

    .ride-left {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .ride-icon {
      font-size: 32px;
      width: 44px;
      text-align: center;
      flex-shrink: 0;
    }

    .ride-name {
      font-size: 18px;
      font-weight: 800;
      margin-bottom: 4px;
    }

    .ride-desc {
      font-size: 14px;
      color: #6b7280;
      line-height: 1.4;
    }

    .ride-price {
      font-size: 24px;
      font-weight: 800;
      white-space: nowrap;
      margin-left: 16px;
    }

    .submit-btn {
      width: 100%;
      height: 92px;
      border: none;
      border-radius: 24px;
      background: #000;
      color: #fff;
      font-size: 20px;
      font-weight: 800;
      cursor: pointer;
      margin-top: 18px;
    }

    .submit-btn:disabled {
      opacity: 0.7;
      cursor: not-allowed;
    }

    .message {
      margin-top: 16px;
      padding: 14px 16px;
      border-radius: 16px;
      font-size: 15px;
      display: none;
      line-height: 1.4;
    }

    .message.success {
      display: block;
      background: #e8f8ee;
      color: #146534;
      border: 1px solid #b7e4c7;
    }

    .message.error {
      display: block;
      background: #fdecec;
      color: #991b1b;
      border: 1px solid #f5b5b5;
    }
  </style>
</head>
<body>
  <div class="page">
    <a href="/" class="back">← Back</a>

    <h1>Request a Ride</h1>
    <p class="subtitle">
      Enter your ride details below and choose the service you want.
    </p>

    <label class="label" for="pickup">Pickup location</label>
    <input class="input" id="pickup" type="text" placeholder="Enter pickup address" />

    <label class="label" for="destination">Destination</label>
    <input class="input" id="destination" type="text" placeholder="Enter destination" />

    <label class="label" for="passengerName">Passenger name</label>
    <input class="input" id="passengerName" type="text" placeholder="Enter your full name" />

    <h2 class="section-title">Choose ride type</h2>

    <div class="ride-option active" onclick="selectRide('Harvey Standard', this)">
      <div class="ride-left">
        <div class="ride-icon">🚕</div>
        <div>
          <div class="ride-name">Harvey Standard</div>
          <div class="ride-desc">Affordable everyday ride</div>
        </div>
      </div>
      <div class="ride-price">$12</div>
    </div>

    <div class="ride-option" onclick="selectRide('Harvey XL', this)">
      <div class="ride-left">
        <div class="ride-icon">🚐</div>
        <div>
          <div class="ride-name">Harvey XL</div>
          <div class="ride-desc">More room for passengers and bags</div>
        </div>
      </div>
      <div class="ride-price">$18</div>
    </div>

    <div class="ride-option" onclick="selectRide('Airport Ride', this)">
      <div class="ride-left">
        <div class="ride-icon">✈️</div>
        <div>
          <div class="ride-name">Airport Ride</div>
          <div class="ride-desc">Easy rides to and from BNA</div>
        </div>
      </div>
      <div class="ride-price">$25</div>
    </div>

    <button id="submitBtn" class="submit-btn" onclick="requestRide()">Request Ride</button>
    <div id="messageBox" class="message"></div>
  </div>

  <script>
    let selectedRideType = 'Harvey Standard';

    function selectRide(type, element) {
      selectedRideType = type;
      document.querySelectorAll('.ride-option').forEach(card => {
        card.classList.remove('active');
      });
      element.classList.add('active');
    }

    async function requestRide() {
      const pickup = document.getElementById('pickup').value.trim();
      const destination = document.getElementById('destination').value.trim();
      const passengerName = document.getElementById('passengerName').value.trim();
      const submitBtn = document.getElementById('submitBtn');
      const messageBox = document.getElementById('messageBox');

      messageBox.className = 'message';
      messageBox.style.display = 'none';
      messageBox.textContent = '';

      if (!pickup || !destination || !passengerName) {
        messageBox.className = 'message error';
        messageBox.textContent = 'Please fill in pickup location, destination, and passenger name.';
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Requesting...';

      try {
        const response = await fetch('/request-ride', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            pickup,
            destination,
            passengerName,
            rideType: selectedRideType
          })
        });

        const data = await response.json();

        if (data.success) {
          messageBox.className = 'message success';
          messageBox.textContent = `Success: ${data.message}`;
          document.getElementById('pickup').value = '';
          document.getElementById('destination').value = '';
          document.getElementById('passengerName').value = '';
        } else {
          messageBox.className = 'message error';
          messageBox.textContent = data.message || 'Something went wrong.';
        }
      } catch (error) {
        messageBox.className = 'message error';
        messageBox.textContent = 'Could not connect to the server.';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Request Ride';
      }
    }
  </script>
</body>
</html>
